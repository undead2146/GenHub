<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:GenHub.Features.GitHub.ViewModels"
             xmlns:local="using:GenHub.Features.GitHub.Views"
             xmlns:conv="using:GenHub.Infrastructure.Converters"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="700"
             x:Class="GenHub.Features.GitHub.Views.GitHubDisplayItemsView"
             x:CompileBindings="False">

    <UserControl.Resources>
        <conv:IconKeyToPathDataConverter x:Key="IconKeyToPathDataConverter" />
        <conv:BoolToColorConverter x:Key="BoolToColorConverter" TrueColor="LightGreen" FalseColor="White" />
        
        <StreamGeometry x:Key="RefreshIcon">M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z</StreamGeometry>
        <StreamGeometry x:Key="SearchIcon">M15.5,14.5L20,19L19,20L14.5,15.5C13.2,16.5 11.7,17 10,17C7.3,17 5.1,16.1 3.3,14.3C1.5,12.5 0.6,10.3 0.6,7.6C0.6,4.9 1.5,2.7 3.3,0.9C5.1,0.1 7.3,-0.8 10,-0.8C12.7,-0.8 14.9,0.1 16.7,1.9C18.5,3.7 19.4,5.9 19.4,8.6C19.4,10.3 18.9,11.8 17.9,13.1L15.5,14.5M10,15C12,15 13.7,14.3 15,13C16.3,11.7 17,10 17,8C17,6 16.3,4.3 15,3C13.7,1.7 12,1 10,1C8,1 6.3,1.7 5,3C3.7,4.3 3,6 3,8C3,10 3.7,11.7 5,13C6.3,14.3 8,15 10,15Z</StreamGeometry>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="TreeView">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="Padding" Value="2"/>
        </Style>
        
        <!-- Restore compact expand/collapse toggle button with negative margins -->
        <Style Selector="TreeViewItem ToggleButton">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Margin" Value="-10,0,10,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinWidth" Value="16"/>
            <Setter Property="MinHeight" Value="16"/>
        </Style>
        
        <!-- Style the actual arrow/chevron inside the toggle -->
        <Style Selector="TreeViewItem ToggleButton PathIcon">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        
        <!-- Only apply compensating margin to items that have ToggleButtons (expandable items) -->
        <Style Selector="TreeViewItem:nth-child(n) ContentPresenter">
            <Setter Property="Margin" Value="0,0,0,0"/>
        </Style>
        
        <!-- Apply negative margin only when ToggleButton is present and visible -->
        <Style Selector="TreeViewItem[IsExpanded=True] ContentPresenter, TreeViewItem[IsExpanded=False] ContentPresenter">
            <Setter Property="Margin" Value="-20,0,0,0"/>
        </Style>
        
        <!-- Alternative approach: Target items that have children -->
        <Style Selector="TreeViewItem:has-children ContentPresenter">
            <Setter Property="Margin" Value="-20,0,0,0"/>
        </Style>
        
        <!-- Text wrapping for TreeViewItems -->
        <Style Selector="TreeViewItem TextBlock">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="MaxWidth" Value="250"/>
        </Style>
        
        <!-- Improved styles for better visuals -->
        <Style Selector="ComboBox">
            <Setter Property="MaxDropDownHeight" Value="400"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Background" Value="{DynamicResource ComboBoxBackground}"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        
        <Style Selector="TextBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Background" Value="{DynamicResource TextBoxBackground}"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        
        <Style Selector="Button">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Background" Value="{DynamicResource ButtonBackground}"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        
        <Style Selector="TreeViewItem > ContentPresenter > Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Border.artifact-item">
            <Setter Property="Padding" Value="5" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
        <Style Selector="Border.artifact-item:pointerover">
            <Setter Property="Background" Value="#2A2A2A" />
        </Style>
        <Style Selector="Border.artifact-item.selected">
            <Setter Property="Background" Value="#2D4963" />
        </Style>
        <Style Selector="Border.workflow-group">
            <Setter Property="Padding" Value="5" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="Background" Value="#1A1A1A" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <!-- Repository Selection -->
        <Grid Grid.Row="0" RowDefinitions="Auto,Auto" Margin="8,12,8,6">
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                <ComboBox Grid.Column="0" 
                          HorizontalAlignment="Stretch"
                          ItemsSource="{Binding RepositoryControlVM.Repositories}"
                          SelectedItem="{Binding RepositoryControlVM.SelectedRepository}"
                          DisplayMemberBinding="{Binding DisplayName}"/>
                <Button Grid.Column="1" 
                        Margin="6,0,0,0" 
                        Command="{Binding RefreshCommand}">
                    <PathIcon Data="{StaticResource RefreshIcon}" Width="16" Height="16"/>
                </Button>
            </Grid>
            <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,6,0,0">
                <TextBox Grid.Column="0" 
                         Watermark="Add repository: owner/name"
                         Text="{Binding RepositoryControlVM.UserInputCustomRepo}"/>
                <Button Grid.Column="1" 
                        Margin="6,0,0,0"
                        Command="{Binding RepositoryControlVM.SearchRepositoryCommand}"
                        IsEnabled="{Binding !RepositoryControlVM.IsSearchingRepository}">
                    <PathIcon Data="{StaticResource SearchIcon}" Width="16" Height="16"/>
                </Button>
            </Grid>
        </Grid>
            
        <!-- Workflow Filter -->
        <Grid Grid.Row="1" Margin="8,6,8,6">
            <ComboBox HorizontalAlignment="Stretch"
                      ItemsSource="{Binding ContentModeFilterVM.AvailableWorkflows}"
                      SelectedItem="{Binding ContentModeFilterVM.SelectedWorkflow}"
                      DisplayMemberBinding="{Binding DisplayName}"/>
        </Grid>
            
        <!-- GitHub Items TreeView -->
        <Grid Grid.Row="2" RowDefinitions="Auto,*" Margin="8,6,8,6">
            <!-- Search Box -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                <TextBox x:Name="SearchBox"
                         Grid.Column="0" 
                         Watermark="Search items..." 
                         Text="{Binding GitHubItemsTreeVM.SearchQuery, Mode=TwoWay}"
                         Margin="0,0,0,6" />
                <Button Grid.Column="1"
                        Margin="6,0,0,0"
                        Command="{Binding GitHubItemsTreeVM.ExecuteServerSearchCommand}">
                    <PathIcon Data="{StaticResource SearchIcon}" Width="16" Height="16"/>
                </Button>
            </Grid>
                
            <!-- TreeView with proper layout properties -->
            <TreeView Grid.Row="1"
                      ItemsSource="{Binding GitHubItemsTreeVM.FilteredGitHubItems}"
                      SelectedItem="{Binding GitHubItemsTreeVM.SelectedGitHubItem, Mode=TwoWay}"
                      AutoScrollToSelectedItem="True"
                      Background="{DynamicResource TreeViewBackground}"
                      BorderThickness="1"
                      BorderBrush="{DynamicResource BorderBrush}"
                      CornerRadius="4">
                <TreeView.ItemTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <PathIcon Data="{Binding IconKey, Converter={StaticResource IconKeyToPathDataConverter}}" 
                                      Width="16" Height="16" 
                                      Foreground="{Binding IsActive, Converter={StaticResource BoolToColorConverter}}"
                                      VerticalAlignment="Center"
                                      Margin="0,2,0,0"/>
                            <TextBlock Text="{Binding DisplayName}" 
                                       TextWrapping="Wrap" 
                                       MaxWidth="220"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Grid>
            
        <!-- Status Bar -->
        <!-- Status Bar that appears above all other content -->
        <Grid Grid.Row="3" 
            Background="{DynamicResource StatusBarBackground}" 
            Height="26" 
            Margin="0,6,0,0"
            ZIndex="1000">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
              <TextBlock Text="{Binding StatusMessage}" 
                     VerticalAlignment="Center"
                     HorizontalAlignment="Left"
                     Margin="12,0"
                     Padding="0,4"
                     TextTrimming="CharacterEllipsis"
                     ToolTip.Tip="{Binding StatusMessage}"
                     Foreground="{DynamicResource StatusBarForeground}"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:GenHub.Features.GitHub.ViewModels"
             xmlns:items="using:GenHub.Features.GitHub.ViewModels"
             xmlns:conv="using:GenHub.Infrastructure.Converters"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="GenHub.Features.GitHub.Views.GitHubDisplayItemsView"
             x:DataType="vm:GitHubItemsTreeViewModel">

  <UserControl.Resources>
    <conv:IconKeyToPathDataConverter x:Key="IconConverter"/>
    <conv:NotNullConverter x:Key="NotNullConverter"/>
  </UserControl.Resources>

  <UserControl.Styles>
    <!-- Enhanced TreeView Styles for Search Results -->
    <Style Selector="TreeView">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
      <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
    </Style>
    
    <!-- Search Result Item Highlighting -->
    <Style Selector="TreeViewItem.search-result">
      <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAccentBrush}"/>
      <Setter Property="Foreground" Value="White"/>
    </Style>
    
    <Style Selector="TreeViewItem.search-result:selected">
      <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
    </Style>
    
    <!-- Workflow Item Styles -->
    <Style Selector="Border.workflow-item">
      <Setter Property="Padding" Value="8"/>
      <Setter Property="Margin" Value="2"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>
    
    <Style Selector="Border.workflow-item:pointerover">
      <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
    </Style>
    
    <Style Selector="Border.workflow-item.selected">
      <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListLowBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource SystemControlHighlightBaseMediumBrush}"/>
    </Style>
    
    <!-- Search Context Badge -->
    <Style Selector="Border.context-badge">
      <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAccentBrush}"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="6,2"/>
      <Setter Property="Margin" Value="4,0,0,0"/>
    </Style>
    
    <Style Selector="TextBlock.context-badge-text">
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="FontWeight" Value="Medium"/>
    </Style>
    
    <!-- Search Match Highlighting -->
    <Style Selector="TextBlock.search-highlight">
      <Setter Property="Background" Value="Yellow"/>
      <Setter Property="Foreground" Value="Black"/>
      <Setter Property="Padding" Value="2,0"/>
    </Style>

    <!-- Fixed Loading Ring Animation -->
    <Style Selector="Border.loading-ring">
      <Style.Animations>
        <Animation Duration="0:0:1" IterationCount="Infinite">
          <KeyFrame Cue="0%">
            <Setter Property="RotateTransform.Angle" Value="0"/>
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="RotateTransform.Angle" Value="360"/>
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
  </UserControl.Styles>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Search Results Header -->
    <Border Grid.Row="0" 
            Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
            Padding="12,8"
            IsVisible="{Binding IsSearchActive}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Search Icon and Results Count -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
          <TextBlock Text="{Binding SearchResultCount, StringFormat='{}{0} Results'}" 
                     FontWeight="Medium" 
                     VerticalAlignment="Center" />
        </StackPanel>

        <!-- Search Context Information -->
        <StackPanel Grid.Column="1" 
                    Orientation="Horizontal" 
                    VerticalAlignment="Center"
                    Margin="12,0,0,0">
          <TextBlock Text="for" 
                     FontSize="12" 
                     Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                     VerticalAlignment="Center"
                     Margin="0,0,4,0"/>
          <TextBlock Text="{Binding SearchText}" 
                     FontWeight="Medium"
                     FontSize="12"
                     VerticalAlignment="Center"
                     Margin="0,0,4,0"/>
          <TextBlock Text="in" 
                     FontSize="12" 
                     Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                     VerticalAlignment="Center"
                     Margin="0,0,4,0"/>
          <Border Classes="context-badge">
            <TextBlock Classes="context-badge-text"
                       Text="{Binding GetCurrentWorkflowPath, TargetNullValue='All Items'}" />
          </Border>
        </StackPanel>

        <!-- Clear Search Button -->
        <Button Grid.Column="2"
                Content="✕"
                Command="{Binding ClearSearchCommand}"
                Background="Transparent"
                BorderThickness="0"
                Padding="6"
                ToolTip.Tip="Clear search"/>
      </Grid>
    </Border>

    <!-- Main Content Area -->
    <ScrollViewer Grid.Row="1" Padding="10">
      <Grid>
        <!-- Loading Indicator -->
        <StackPanel IsVisible="{Binding IsLoading}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Horizontal" 
                    Spacing="10">
          <Border Width="24" Height="24" 
                  BorderBrush="{DynamicResource SystemAccentColor}"
                  BorderThickness="3"
                  CornerRadius="12"
                  Classes="loading-ring">
            <Border.RenderTransform>
              <RotateTransform/>
            </Border.RenderTransform>
          </Border>
          <TextBlock Text="Loading..." 
                     VerticalAlignment="Center"
                     FontSize="14" />
        </StackPanel>

        <!-- Empty State -->
        <Grid IsVisible="{Binding ShowEmptyState}"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
          <StackPanel Spacing="15">
            <Border Width="64" Height="64"
                    Background="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                    CornerRadius="32"
                    Opacity="0.5"
                    HorizontalAlignment="Center">
              <TextBlock Text="📭" 
                         FontSize="32" 
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="No items found" 
                       FontSize="18"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Try adjusting your search criteria or select a different repository" 
                       FontSize="14"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       MaxWidth="300"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Grid>

        <!-- TreeView for Items with Hierarchical Display -->
        <TreeView ItemsSource="{Binding Items}"
                  SelectedItem="{Binding SelectedGitHubItem, Mode=TwoWay}"
                  IsVisible="{Binding HasItems}"
                  AutoScrollToSelectedItem="True">
          <TreeView.ItemTemplate>
            <TreeDataTemplate ItemsSource="{Binding Children}">
              <Border Background="Transparent"
                      Padding="8"
                      Margin="2"
                      CornerRadius="4"
                      Classes="workflow-item">
                
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>

                  <!-- Icon -->
                  <Border Grid.Column="0"
                          Width="32" Height="32"
                          Background="{DynamicResource SystemAccentColorLight1}"
                          CornerRadius="16"
                          Margin="0,0,12,0"
                          VerticalAlignment="Top">
                    <PathIcon Data="{Binding IconKey, Converter={StaticResource IconConverter}}" 
                              Width="16" Height="16"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center" />
                  </Border>

                  <!-- Content -->
                  <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Text="{Binding DisplayName}" 
                               FontSize="14"
                               FontWeight="SemiBold" 
                               TextWrapping="Wrap" />
                    
                    <TextBlock Text="{Binding Description}" 
                               FontSize="12"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               TextWrapping="Wrap" />
                    
                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4,0,0">
                      <TextBlock Text="{Binding SortDate, StringFormat=\{0:yyyy-MM-dd HH:mm\}}" 
                                 FontSize="11"
                                 Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                      
                      <TextBlock FontSize="11"
                                 Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                 IsVisible="{Binding RunNumber, Converter={StaticResource NotNullConverter}}"
                                 Text="{Binding RunNumber, StringFormat=Run #{0}}" />
                    </StackPanel>
                  </StackPanel>

                  <!-- Action Buttons -->
                  <StackPanel Grid.Column="2" 
                              Orientation="Horizontal" 
                              Spacing="6"
                              VerticalAlignment="Top">
                    
                    <!-- Download Button -->
                    <Button Content="📥"
                            Command="{Binding DownloadCommand}"
                            IsEnabled="{Binding CanDownload}"
                            IsVisible="{Binding CanDownload}"
                            ToolTip.Tip="Download"
                            Width="28" Height="28"
                            Padding="0" />
                    
                    <!-- Install Button -->
                    <Button Content="⚡"
                            Command="{Binding InstallCommand}"
                            IsEnabled="{Binding CanInstall}"
                            IsVisible="{Binding CanInstall}"
                            ToolTip.Tip="Install"
                            Width="28" Height="28"
                            Padding="0" />
                  </StackPanel>
                </Grid>
              </Border>
            </TreeDataTemplate>
          </TreeView.ItemTemplate>
        </TreeView>
      </Grid>
    </ScrollViewer>

    <!-- Footer -->
    <Border Grid.Row="2" 
            Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0,1,0,0"
            Padding="12,6"
            IsVisible="{Binding Items.Count, Converter={StaticResource NotNullConverter}}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Item Summary -->
        <TextBlock Grid.Column="0"
                   FontSize="11"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                   VerticalAlignment="Center"
                   Text="{Binding Items.Count, StringFormat='{}{0} items displayed'}" />

        <!-- Search Context -->
        <TextBlock Grid.Column="1"
                   FontSize="11"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                   VerticalAlignment="Center"
                   IsVisible="{Binding IsSearchActive}"
                   Text="{Binding SearchText, StringFormat='Filtered by: {0}'}" />
      </Grid>
    </Border>
  </Grid>
</UserControl>

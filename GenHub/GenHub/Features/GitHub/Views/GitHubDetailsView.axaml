<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:GenHub.Features.GitHub.ViewModels"
             xmlns:conv="using:GenHub.Infrastructure.Converters"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="400"
             x:Class="GenHub.Features.GitHub.Views.GitHubDetailsView"
             x:DataType="vm:GitHubDetailsViewModel">

  <UserControl.Resources>
    <conv:FileSizeConverter x:Key="FileSizeConverter"/>
    <conv:IconKeyToPathDataConverter x:Key="IconConverter"/>
    <conv:NotNullConverter x:Key="NotNullConverter"/>
  </UserControl.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Header -->
    <Border Grid.Row="0" 
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0,0,0,1"
            Padding="15,10">
      <TextBlock Text="Details" 
                 FontSize="16" 
                 FontWeight="SemiBold" />
    </Border>

    <!-- Content -->
    <ScrollViewer Grid.Row="1" Padding="15">
      <StackPanel Spacing="15">
        
        <!-- Artifact Details  -->
        <StackPanel Spacing="12" 
                    IsVisible="{Binding HasSelectedArtifact}">
          <TextBlock Text="Artifact Details" 
                     FontSize="14" 
                     FontWeight="SemiBold" />
          
          <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" 
                RowSpacing="8" ColumnSpacing="12">
            
            <!-- Name  -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" FontWeight="Medium" />
            <TextBlock Grid.Row="0" Grid.Column="1" 
                       Text="{Binding SelectedArtifact.DisplayName, FallbackValue='N/A'}" 
                       TextWrapping="Wrap" />
            
            <!-- Size -->
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Size:" FontWeight="Medium" />
            <TextBlock Grid.Row="1" Grid.Column="1">
              <TextBlock.Text>
                <MultiBinding StringFormat="{}{0}">
                  <Binding Path="SelectedArtifact.SizeInBytes" 
                           Converter="{StaticResource FileSizeConverter}" 
                           FallbackValue="Unknown" />
                </MultiBinding>
              </TextBlock.Text>
            </TextBlock>
            
            <!-- Run Number with Safe Binding -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Run #:" FontWeight="Medium" />
            <TextBlock Grid.Row="2" Grid.Column="1" 
                       Text="{Binding SelectedArtifact.WorkflowNumber, FallbackValue='N/A'}" />
            
            <!-- Created with Safe Date Formatting -->
            <TextBlock Grid.Row="3" Grid.Column="0" Text="Created:" FontWeight="Medium" />
            <TextBlock Grid.Row="3" Grid.Column="1">
              <TextBlock.Text>
                <MultiBinding StringFormat="{}{0:g}">
                  <Binding Path="SelectedArtifact.CreatedAt" FallbackValue="Unknown" />
                </MultiBinding>
              </TextBlock.Text>
            </TextBlock>
            
            <!-- Build Info with Null Checks -->
            <TextBlock Grid.Row="4" Grid.Column="0" Text="Build:" FontWeight="Medium" 
                       IsVisible="{Binding SelectedArtifact.BuildInfo, Converter={x:Static ObjectConverters.IsNotNull}}" />
            <StackPanel Grid.Row="4" Grid.Column="1" Spacing="4"
                        IsVisible="{Binding SelectedArtifact.BuildInfo, Converter={x:Static ObjectConverters.IsNotNull}}">
              <TextBlock Text="{Binding SelectedArtifact.BuildInfo.GameVariant, FallbackValue='N/A'}" FontSize="12" />
              <TextBlock Text="{Binding SelectedArtifact.BuildInfo.Configuration, FallbackValue='N/A'}" FontSize="12" 
                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
            </StackPanel>
          </Grid>
        </StackPanel>

        <!-- Workflow Details with Safe Binding -->
        <StackPanel Spacing="12" 
                    IsVisible="{Binding HasSelectedWorkflow}">
          <TextBlock Text="Workflow Details" 
                     FontSize="14" 
                     FontWeight="SemiBold" />
          
          <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" 
                RowSpacing="8" ColumnSpacing="12">
            
            <!-- Workflow Name -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Workflow:" FontWeight="Medium" />
            <TextBlock Grid.Row="0" Grid.Column="1" 
                       Text="{Binding SelectedWorkflow.WorkflowName, FallbackValue='N/A'}" 
                       TextWrapping="Wrap" />
            
            <!-- Run Number -->
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Run #:" FontWeight="Medium" />
            <TextBlock Grid.Row="1" Grid.Column="1" 
                       Text="{Binding SelectedWorkflow.WorkflowNumber, FallbackValue='N/A'}" />
            
            <!-- Commit Message -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Commit:" FontWeight="Medium" />
            <TextBlock Grid.Row="2" Grid.Column="1" 
                       Text="{Binding SelectedWorkflow.CommitMessage, FallbackValue='N/A'}" 
                       TextWrapping="Wrap" MaxWidth="200" />
            
            <!-- Pull Request with Safe Visibility -->
            <TextBlock Grid.Row="3" Grid.Column="0" Text="PR:" FontWeight="Medium" 
                       IsVisible="{Binding SelectedWorkflow.PullRequestNumber, Converter={x:Static ObjectConverters.IsNotNull}}" />
            <StackPanel Grid.Row="3" Grid.Column="1" Spacing="2"
                        IsVisible="{Binding SelectedWorkflow.PullRequestNumber, Converter={x:Static ObjectConverters.IsNotNull}}">
              <TextBlock Text="{Binding SelectedWorkflow.PullRequestNumber, StringFormat='#{0}', FallbackValue='N/A'}" FontSize="12" />
              <TextBlock Text="{Binding SelectedWorkflow.PullRequestTitle, FallbackValue='N/A'}" FontSize="12" 
                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                         TextWrapping="Wrap" MaxWidth="200" />
            </StackPanel>
            
            <!-- Created Date -->
            <TextBlock Grid.Row="4" Grid.Column="0" Text="Created:" FontWeight="Medium" />
            <TextBlock Grid.Row="4" Grid.Column="1">
              <TextBlock.Text>
                <MultiBinding StringFormat="{}{0:g}">
                  <Binding Path="SelectedWorkflow.CreatedAt" FallbackValue="Unknown" />
                </MultiBinding>
              </TextBlock.Text>
            </TextBlock>
          </Grid>

          <!-- Workflow Run Items (Artifacts) -->
          <StackPanel Spacing="8" IsVisible="{Binding HasWorkflowRunItems}">
            <TextBlock Text="Artifacts" FontWeight="Medium" FontSize="12" />
            <ListBox ItemsSource="{Binding WorkflowRunItems}" 
                     SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                     MaxHeight="200"
                     Background="Transparent"
                     BorderThickness="1"
                     BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                     CornerRadius="4">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Border Padding="8,4" Background="Transparent">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <PathIcon Data="{Binding IconKey, Converter={StaticResource IconConverter}}" 
                                Width="16" Height="16" />
                      <TextBlock Text="{Binding DisplayName, FallbackValue='Unknown Item'}" VerticalAlignment="Center" />
                      <Button Content="Select" 
                              Command="{Binding $parent[UserControl].DataContext.SelectItemCommand}"
                              CommandParameter="{Binding}"
                              Classes="accent"
                              FontSize="10"
                              Padding="6,2" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </StackPanel>
        </StackPanel>

        <!-- Release Details-->
        <StackPanel Spacing="12" 
                    IsVisible="{Binding HasSelectedRelease}">
          <TextBlock Text="Release Details" 
                     FontSize="14" 
                     FontWeight="SemiBold" />
          
          <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" 
                RowSpacing="8" ColumnSpacing="12">
            
            <!-- Name -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" FontWeight="Medium" />
            <TextBlock Grid.Row="0" Grid.Column="1" 
                       Text="{Binding SelectedRelease.DisplayName, FallbackValue='N/A'}" 
                       TextWrapping="Wrap" />
            
            <!-- Tag -->
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Tag:" FontWeight="Medium" />
            <TextBlock Grid.Row="1" Grid.Column="1" 
                       Text="{Binding SelectedRelease.TagName, FallbackValue='N/A'}" />
            
            <!-- Status with Safe Boolean Binding -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Status:" FontWeight="Medium" />
            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="4">
              <Border Background="#FFD700" CornerRadius="8" Padding="4,1"
                      IsVisible="{Binding SelectedRelease.IsDraft, FallbackValue=False}">
                <TextBlock Text="Draft" FontSize="10" Foreground="Black" />
              </Border>
              <Border Background="#FF7F50" CornerRadius="8" Padding="4,1"
                      IsVisible="{Binding SelectedRelease.IsPrerelease, FallbackValue=False}">
                <TextBlock Text="Pre-release" FontSize="10" Foreground="White" />
              </Border>
            </StackPanel>
            
            <!-- Published Date -->
            <TextBlock Grid.Row="3" Grid.Column="0" Text="Published:" FontWeight="Medium" />
            <TextBlock Grid.Row="3" Grid.Column="1">
              <TextBlock.Text>
                <MultiBinding StringFormat="{}{0:g}">
                  <Binding Path="SelectedRelease.PublishedAt" FallbackValue="Unknown" />
                </MultiBinding>
              </TextBlock.Text>
            </TextBlock>
          </Grid>

          <!-- Release Body with Safe String Binding -->
          <StackPanel Spacing="8" 
                      IsVisible="{Binding SelectedRelease.Body, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="Release Notes" FontWeight="Medium" FontSize="12" />
            <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                    CornerRadius="4" Padding="8" MaxHeight="150">
              <ScrollViewer>
                <TextBlock Text="{Binding SelectedRelease.Body, FallbackValue=''}" 
                           TextWrapping="Wrap" FontSize="12" />
              </ScrollViewer>
            </Border>
          </StackPanel>
        </StackPanel>

        <!-- No Selection Message -->
        <StackPanel Spacing="8" 
                    IsVisible="{Binding SelectedItem, Converter={x:Static ObjectConverters.IsNull}}"
                    HorizontalAlignment="Center">
          <TextBlock Text="ℹ️" 
                     FontSize="32"
                     HorizontalAlignment="Center"
                     Opacity="0.5" />
          <TextBlock Text="No item selected" 
                     FontSize="14"
                     HorizontalAlignment="Center"
                     Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
          <TextBlock Text="Select an item to view details" 
                     FontSize="12"
                     HorizontalAlignment="Center"
                     TextAlignment="Center"
                     Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
        </StackPanel>

      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>

<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:GenHub.Features.GitHub.ViewModels"
    xmlns:views="using:GenHub.Features.GitHub.Views"
    mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
    x:Class="GenHub.Features.GitHub.Views.GitHubManagerWindow"
    x:DataType="vm:GitHubManagerViewModel"
    Title="GitHub Manager"
    Width="1200" Height="800"
    MinWidth="800" MinHeight="600">

    <Window.Styles>
        <!-- Ensure no problematic animations are applied -->
        <Style Selector="Border">
            <Setter Property="Transitions" Value="" />
        </Style>
        <Style Selector="UserControl">
            <Setter Property="Transitions" Value="" />
        </Style>
    </Window.Styles>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
            Background="{DynamicResource SystemAccentColorDark1}"
            Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="GitHub Manager"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Foreground="White"
                        VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                    <Button Content="Configure Token"
                        Command="{Binding ConfigureTokenCommand}"
                        Classes="accent" />
                    <Button Content="Refresh"
                        Command="{Binding RefreshCommand}"
                        Classes="accent" />
                    <Button Content="Close"
                        Command="{Binding CloseWindowCommand}"
                        Classes="accent" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Repository and Content Mode Controls -->
        <Border Grid.Row="1"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0,0,0,1"
            Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Repository Selection Section - Enhanced with Discovery -->
                <StackPanel Orientation="Horizontal" Spacing="10" Margin="10">
                    <TextBlock Text="Repository:" VerticalAlignment="Center" FontWeight="Bold" />

                    <!-- Repository ComboBox -->
                    <ComboBox
                        ItemsSource="{Binding RepositoryControlVM.Repositories}"
                        SelectedItem="{Binding RepositoryControlVM.SelectedRepository}"
                        MinWidth="250"
                        MaxWidth="400"
                        IsEnabled="{Binding !RepositoryControlVM.IsLoading}">
                        
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Spacing="4" Margin="4">
                                    <TextBlock Text="{Binding ComputedDisplayName}" 
                                               FontWeight="SemiBold"
                                               FontSize="13" />
                                    <TextBlock Text="{Binding Description}" 
                                               FontSize="11"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                               TextWrapping="Wrap"
                                               MaxWidth="300" />
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                        
                        <ComboBox.SelectionBoxItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ComputedDisplayName}" 
                                           VerticalAlignment="Center" />
                            </DataTemplate>
                        </ComboBox.SelectionBoxItemTemplate>
                    </ComboBox>

                    <!-- Loading indicator for repositories -->
                    <ProgressBar IsIndeterminate="True" 
                                 IsVisible="{Binding RepositoryControlVM.IsLoading}"
                                 Width="20" Height="20"
                                 Margin="8,0,0,0" />
                    
                    <!-- Discovery indicator -->
                    <ProgressBar IsIndeterminate="True" 
                                 IsVisible="{Binding RepositoryControlVM.IsDiscovering}"
                                 Width="20" Height="20"
                                 Margin="8,0,0,0"
                                 Foreground="Orange" />
                    
                    <!-- Discovery button -->
                    <Button Command="{Binding RepositoryControlVM.DiscoverRepositoriesCommand}"
                            Content="🔍" 
                            ToolTip.Tip="Discover C&amp;C Repositories"
                            Width="32" Height="32"
                            Padding="0"
                            IsEnabled="{Binding !RepositoryControlVM.IsDiscovering}" />
                </StackPanel>

                <!-- Status message for repository operations -->
                <TextBlock Text="{Binding RepositoryControlVM.StatusMessage}" 
                           Margin="10,5"
                           FontSize="11"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           IsVisible="{Binding RepositoryControlVM.StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                <!-- Content Mode Filter -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Show:"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0"
                        FontWeight="Medium" />

                    <!-- Display Mode Selector -->
                    <ComboBox ItemsSource="{Binding ContentModeFilterVM.DisplayModes}"
                        SelectedItem="{Binding ContentModeFilterVM.CurrentDisplayMode}"
                        MinWidth="120"
                        Margin="0,0,16,0" />

                    <!-- Workflow Selector -->
                    <TextBlock Text="Workflow:"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0"
                        FontWeight="Medium"
                        IsVisible="{Binding ContentModeFilterVM.ShowWorkflowSelector}" />
                    <ComboBox ItemsSource="{Binding ContentModeFilterVM.AvailableWorkflows}"
                        SelectedItem="{Binding ContentModeFilterVM.SelectedWorkflow}"
                        MinWidth="200"
                        DisplayMemberBinding="{Binding DisplayName}"
                        IsVisible="{Binding ContentModeFilterVM.ShowWorkflowSelector}" />
                </StackPanel>

                <!-- Search Controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                    IsVisible="{Binding ContentModeFilterVM.ShowSearchControls}">
                    <ComboBox ItemsSource="{Binding ContentModeFilterVM.SearchCriteriaOptions}"
                        SelectedItem="{Binding ContentModeFilterVM.SelectedSearchCriteria}"
                        MinWidth="120"
                        Margin="0,0,8,0" />
                    <TextBox Text="{Binding GitHubItemsTreeVM.SearchText}"
                        Watermark="Search..."
                        MinWidth="150"
                        Margin="0,0,8,0" />
                    <Button Content="Search"
                        Command="{Binding GitHubItemsTreeVM.SearchCommand}"
                        Margin="0,0,4,0" />
                    <Button Content="Clear"
                        Command="{Binding GitHubItemsTreeVM.ClearSearchCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <!-- Items Tree -->
            <Border Grid.Column="0" Padding="10">
                <ContentControl Content="{Binding GitHubItemsTreeVM}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate>
                            <views:GitHubDisplayItemsView />
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </Border>

            <!-- Vertical Splitter -->
            <GridSplitter Grid.Column="1"
                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                HorizontalAlignment="Stretch" />

            <!-- Right Panel -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="5" />
                    <RowDefinition Height="200" />
                </Grid.RowDefinitions>

                <!-- Details View -->
                <Border Grid.Row="0" Padding="0">
                    <ContentControl Content="{Binding DetailsVM}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate>
                                <views:GitHubDetailsView />
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>
                </Border>

                <!-- Horizontal Splitter -->
                <GridSplitter Grid.Row="1"
                    Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                    VerticalAlignment="Stretch" />

                <!-- Installation Panel -->
                <Border Grid.Row="2" Padding="0">
                    <ContentControl Content="{Binding InstallationVM}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate>
                                <views:InstallationView />
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>
                </Border>
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="3"
            Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
            Padding="15,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                    Text="{Binding StatusMessage}"
                    VerticalAlignment="Center" />

                <!-- Simple Loading indicator without animations -->
                <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="10"
                    IsVisible="{Binding IsLoading}">
                    <TextBlock Text="Loading..."
                        VerticalAlignment="Center" />
                    <ProgressBar IsIndeterminate="True"
                        Width="20"
                        Height="20" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading Overlay with proper styling -->
        <Panel Grid.RowSpan="4"
            IsVisible="{Binding IsLoading}"
            ZIndex="100">
            <Border Background="#80000000" />
            <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="15">
                <TextBlock Text="Loading..."
                    FontSize="16"
                    Foreground="White"
                    HorizontalAlignment="Center" />
                <ProgressBar IsIndeterminate="True"
                    Width="200"
                    Height="4"
                    Foreground="White" />
            </StackPanel>
        </Panel>
    </Grid>
</Window>

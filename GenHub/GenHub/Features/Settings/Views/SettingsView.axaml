<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:GenHub.Features.Settings.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="GenHub.Features.Settings.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             Background="#1A1A1A">

    <UserControl.Styles>
        <Style Selector="Border.settings-card">
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="10" />
            <Setter Property="BoxShadow" Value="0 2 8 0 #20000000" />
        </Style>
    </UserControl.Styles>
    
    <ScrollViewer>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            
            <!-- Header Section -->
            <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,40">
                <TextBlock Text="{Binding Title}" 
                           FontSize="28" 
                           FontWeight="SemiBold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10" />
                <TextBlock Text="{Binding Description}"
                           FontSize="16"
                           Foreground="#AAAAAA"
                           HorizontalAlignment="Center" />
            </StackPanel>
            
            <!-- Settings Content -->
            <StackPanel Grid.Row="1" HorizontalAlignment="Center" MaxWidth="600">
                <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <!-- Application Settings -->
                    <Border Classes="settings-card" MinWidth="250" MinHeight="150">
                        <StackPanel HorizontalAlignment="Center" Spacing="15">
                            <PathIcon Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.22,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.22,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.68 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"
                                      Width="40" Height="40"
                                      Foreground="#666666"
                                      HorizontalAlignment="Center" />
                            <TextBlock Text="Application Settings"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#666666"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Configure app preferences"
                                       FontSize="14"
                                       Foreground="#555555"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="Coming Soon"
                                       FontSize="12"
                                       FontStyle="Italic"
                                       Foreground="#555555"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <!-- Game Settings -->
                    <Border Classes="settings-card" MinWidth="250" MinHeight="150">
                        <StackPanel HorizontalAlignment="Center" Spacing="15">
                            <PathIcon Data="M7.5,4A5.5,5.5 0 0,0 2,9.5C2,10 2.04,10.5 2.14,11H4.21C4.14,10.5 4.14,10 4.21,9.5A3.5,3.5 0 0,1 7.5,6A3.5,3.5 0 0,1 11,9.5H8.5V11H11.03C10.8,11.64 10.4,12.2 9.87,12.65L11.28,14.06C12.33,13.01 13,11.6 13,10C13,6.69 10.31,4 7.5,4M7.5,2A7.5,7.5 0 0,1 15,9.5C15,12.28 13.69,14.75 11.67,16.12L13.08,17.53C15.65,15.76 17.31,12.78 17.31,9.5A9.5,9.5 0 0,0 7.5,0A9.5,9.5 0 0,0 -2,9.5H0A7.5,7.5 0 0,1 7.5,2Z"
                                      Width="40" Height="40"
                                      Foreground="#666666"
                                      HorizontalAlignment="Center" />
                            <TextBlock Text="Game Settings"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#666666"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Configure game defaults"
                                       FontSize="14"
                                       Foreground="#555555"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="Coming Soon"
                                       FontSize="12"
                                       FontStyle="Italic"
                                       Foreground="#555555"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </WrapPanel>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>

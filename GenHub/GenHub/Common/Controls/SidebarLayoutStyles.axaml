<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:GenHub.Common.Controls">
  <Design.PreviewWith>
    <controls:SidebarLayout />
  </Design.PreviewWith>

  <Style Selector="controls|SidebarLayout">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Template">
      <ControlTemplate>
        <Grid>
          <SplitView IsPaneOpen="{TemplateBinding IsPaneOpen, Mode=TwoWay}"
                     DisplayMode="Overlay"
                     OpenPaneLength="{TemplateBinding OpenPaneLength}"
                     PanePlacement="Left"
                     Background="Transparent"
                     PaneBackground="Transparent"> <!-- Explicitly Transparent PaneBackground -->

            <SplitView.Pane>
              <!-- PART_SidebarPane is critical for the hover logic -->
            <Border x:Name="PART_SidebarPane"
                      Background="{StaticResource SidebarBackgroundGradient}"
                      BorderBrush="{StaticResource SidebarGlassBorder}"
                      BorderThickness="0,0,1,0"
                      CornerRadius="0,16,16,0"
                      BoxShadow="4 0 24 -2 #4D000000"> <!-- Subtle Shadow restored -->
                <!-- Removed global Margin="20" to fix indent issue. -->
                <Grid RowDefinitions="Auto,Auto,*,Auto">
                  <!-- Header title - Removed Margin, using Padding for alignment -->
                  <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0" >
                    <TextBlock Text="{TemplateBinding PaneTitle}"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="White"
                               VerticalAlignment="Center"
                               Padding="12,20,12,10"> <!-- Standard Padding -->
                         <TextBlock.Effect>
                             <DropShadowEffect BlurRadius="12" Color="{StaticResource SidebarGlowColor}" Opacity="0.4" OffsetX="0" OffsetY="0"/>
                         </TextBlock.Effect>
                    </TextBlock>

                    <Button Grid.Column="1"
                            Command="{Binding ClosePaneCommand, RelativeSource={RelativeSource TemplatedParent}}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="12"
                            Margin="0,10,0,0"
                            VerticalAlignment="Top"
                            Foreground="{StaticResource PurpleAccentBright}">
                      <TextBlock Text="✕" FontSize="18" FontWeight="Bold"/>
                    </Button>
                  </Grid>

                  <!-- Pane Header (ComboBox) - Flush Left w/ Padding 12 -->
                  <ContentPresenter Grid.Row="1" Content="{TemplateBinding PaneHeader}" Margin="0,0,0,20"/>

                  <!-- List - Flush Left w/ internal item padding 12 -->
                  <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15">
                    <ListBox ItemsSource="{TemplateBinding ItemsSource}"
                             SelectedItem="{TemplateBinding SelectedItem, Mode=TwoWay}"
                             ItemTemplate="{TemplateBinding ItemTemplate}"
                             Background="Transparent">
                         <ListBox.Styles>
            <!-- ListBox Item Stying -->
            <Style Selector="ListBoxItem">
              <!-- Minimal padding, flush left if desired, but 12px is cleaner usually.
                   User said REMOVE INDENT. So I will use very small padding 8px. -->
              <Setter Property="Padding" Value="12,10"/>
              <Setter Property="Margin" Value="0,1"/>
              <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
              <Setter Property="CornerRadius" Value="8"/> <!-- Slightly rounded -->
              <Setter Property="Background" Value="Transparent"/> <!-- Clean Transparent Default -->
              <Setter Property="Transitions">
                  <Transitions>
                      <BrushTransition Property="Background" Duration="0:0:0.2"/>
                      <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2"/>
                  </Transitions>
              </Setter>
            </Style>

            <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
              <Setter Property="Background" Value="{StaticResource SidebarItemHoverBackground}"/>
              <Setter Property="BorderBrush" Value="{StaticResource PurpleAccentMid}"/>
              <Setter Property="BorderThickness" Value="0,0,0,0"/>
            </Style>

            <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
              <Setter Property="Background" Value="{StaticResource SidebarItemSelectedBackground}"/>
              <Setter Property="BorderBrush" Value="{StaticResource PurpleAccentBright}"/>
              <Setter Property="BorderThickness" Value="3,0,0,0"/> <!-- Left accent bar 3px -->
            </Style>

            <Style Selector="ListBoxItem:pointerover">
                <Setter Property="RenderTransform" Value="translateX(4px)"/>
            </Style>
                         </ListBox.Styles>
                    </ListBox>
                  </ScrollViewer>

                  <!-- Footer -->
                  <ContentPresenter Grid.Row="3" Content="{TemplateBinding PaneFooter}"/>
                </Grid>
              </Border>
            </SplitView.Pane>

            <SplitView.Content>
              <Grid>
                <!-- Main Content -->
                <ContentPresenter Content="{TemplateBinding Content}" />

                <!-- Click-outside/Blur overlay -->
                <Panel x:Name="PART_ContentOverlay"
                       Background="#66000000"
                       IsVisible="{TemplateBinding IsPaneOpen}">
                     <Panel.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Opacity" Duration="0:0:0.3"/>
                        </Transitions>
                     </Panel.Transitions>
                </Panel>
              </Grid>
            </SplitView.Content>
          </SplitView>

          <!-- Trigger Zone (Edge Hover Area) -->
          <Panel x:Name="PART_TriggerZone"
                 Width="40"
                 HorizontalAlignment="Left"
                 Background="Transparent"
                 IsVisible="{Binding !IsPaneOpen, RelativeSource={RelativeSource TemplatedParent}}">
             <!-- Visual Hint (Purple Glow Bar) - REMOVED per user feedback ("collapsed line doesn't really fit")
                  Kept invisible panel for hit testing -->
             <Panel Background="Transparent" Width="40" />

             <!-- Hover effect handled by visual state or simple triggers if possible,
                  but the main interaction is handled by code-behind -->
          </Panel>
        </Grid>
      </ControlTemplate>
    </Setter>
  </Style>
</Styles>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:GenHub.Common.ViewModels"
             xmlns:profileViews="clr-namespace:GenHub.Features.GameProfiles.Views"
             xmlns:GitHubManagerWindows="clr-namespace:GenHub.Features.GitHub.Views"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
             x:Class="GenHub.Common.Views.MainView"
             x:DataType="vm:MainViewModel">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header with tabs and update notification button -->
        <Grid Grid.Row="0" Background="#202020">
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="16,10">
                <!-- App icon -->
                <Image Grid.Column="0" 
                       Source="avares://Genhub/Assets/Icons/genhub-icon.png"
                       Height="50" 
                       VerticalAlignment="Center"
                       Margin="0,0,10,0" />
                
                <!-- Center - empty for now -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" 
                           Orientation="Horizontal" Spacing="8">
                </StackPanel>
                
                <!-- Update notification button - positioned in the top-right -->
                <Button Grid.Column="2"
                        Name="UpdateButton" 
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Center"
                        Margin="0,0,10,0"
                        Command="{Binding ShowUpdateNotificationCommand}"
                        ToolTip.Tip="Updates available"
                        Classes="icon-button"
                        Width="32" Height="32">
                    <Panel>
                        <PathIcon Data="M12,4C7,4 2.73,7.11 1,11.5C2.73,15.89 7,19 12,19C17,19 21.27,15.89 23,11.5C21.27,7.11 17,4 12,4ZM12,16.5C9.24,16.5 7,14.26 7,11.5C7,8.74 9.24,6.5 12,6.5C14.76,6.5 17,8.74 17,11.5C17,14.26 14.76,16.5 12,16.5ZM12,8.5A3,3 0 0,0 9,11.5A3,3 0 0,0 12,14.5A3,3 0 0,0 15,11.5A3,3 0 0,0 12,8.5Z" 
                                  Width="16" Height="16"
                                  Foreground="#4CAF50"/>
                        <Ellipse Width="8" Height="8" 
                                 Fill="#FF4500" 
                                 HorizontalAlignment="Right" 
                                 VerticalAlignment="Top" 
                                 Margin="0,-2,-2,0"/>
                    </Panel>
                </Button>
            </Grid>
        </Grid>
        
        <!-- Main content area -->
        <TabControl Grid.Row="1" 
                   Margin="0"
                   SelectedIndex="{Binding SelectedTabIndex}"
                   Background="#1A1A1A"
                   TabStripPlacement="Top">
            <TabItem Header="Game Profiles">
                <profileViews:GameProfileLauncherView/>
            </TabItem>
            <TabItem Header="Downloads">
                <Grid Background="#141414">
                    <StackPanel HorizontalAlignment="Center" 
                               VerticalAlignment="Center" 
                               Spacing="20">
                        <TextBlock Text="Download Game Builds" 
                                  FontSize="24"
                                  HorizontalAlignment="Center"
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,20"/>
                                  
                        <Button Command="{Binding OpenGitHubBuildsCommand}"
                                Classes="accent"
                                Padding="25,15"
                                HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <PathIcon Data="M12,2A10,10 0 0,0 2,12C2,16.42 4.87,20.17 8.84,21.5C9.34,21.58 9.5,21.27 9.5,21C9.5,20.77 9.5,20.14 9.5,19.31C6.73,19.91 6.14,17.97 6.14,17.97C5.68,16.81 5.03,16.5 5.03,16.5C4.12,15.88 5.1,15.9 5.1,15.9C6.1,15.97 6.63,16.93 6.63,16.93C7.5,18.45 8.97,18 9.54,17.76C9.63,17.11 9.89,16.67 10.17,16.42C7.95,16.17 5.62,15.31 5.62,11.5C5.62,10.39 6,9.5 6.65,8.79C6.55,8.54 6.2,7.5 6.75,6.15C6.75,6.15 7.59,5.88 9.5,7.17C10.29,6.95 11.15,6.84 12,6.84C12.85,6.84 13.71,6.95 14.5,7.17C16.41,5.88 17.25,6.15 17.25,6.15C17.8,7.5 17.45,8.54 17.35,8.79C18,9.5 18.38,10.39 18.38,11.5C18.38,15.32 16.04,16.16 13.81,16.41C14.17,16.72 14.5,17.33 14.5,18.26C14.5,19.6 14.5,20.68 14.5,21C14.5,21.27 14.66,21.59 15.17,21.5C19.14,20.16 22,16.42 22,12A10,10 0 0,0 12,2Z" Width="20" Height="20" />
                                <TextBlock Text="Browse GitHub Builds" FontSize="16" />
                            </StackPanel>
                        </Button>
                        
                        <TextBlock Text="Access the latest development builds from GitHub repositories"
                                  Foreground="#AAAAAA" 
                                  TextAlignment="Center" 
                                  TextWrapping="Wrap"
                                  MaxWidth="400" 
                                  Margin="0,20,0,0"/>
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Settings">
                <Grid Background="#141414">
                    <TextBlock Text="Settings coming soon" 
                              HorizontalAlignment="Center" 
                              VerticalAlignment="Center"
                              Foreground="White"
                              FontSize="18"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>

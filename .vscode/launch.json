    "version": "0.2.0",
    "configurations": [
        {
            "name": "GenHub (Main App)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/GenHub/GenHub/bin/Debug/net9.0/GenHub.dll",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "console": "internalConsole"
        },
        {
            "name": "GenHub.Windows",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/GenHub/GenHub.Windows/bin/Debug/net9.0-windows/GenHub.Windows.dll",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "console": "internalConsole"
        },
        {
            "name": "GenHub.Linux",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/GenHub/GenHub.Linux/bin/Debug/net9.0/GenHub.Linux.dll",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "console": "internalConsole"
        },
        {
            "name": "Test Runner",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/GenHub/Tests/TestRunner/bin/Debug/net9.0/TestRunner.dll",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "console": "internalConsole"
        },        {
            "name": "Core Tests",
            "type": "coreclr",
            "request": "launch",
            "program": "dotnet",
            "args": ["test", "${workspaceFolder}/GenHub/GenHub.Tests/GenHub.Tests.Core/GenHub.Tests.Core.csproj", "--verbosity", "normal"],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "console": "internalConsole"
        },
        {
            "name": "All Tests",
            "type": "coreclr",
            "request": "launch",
            "program": "dotnet",
            "args": ["test", "${workspaceFolder}/GenHub/GenHub.sln", "--verbosity", "normal"],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "console": "internalConsole"
        },
        {
            "name": "Attach to Process",
            "type": "coreclr",
            "request": "attach"
        }
    ]
}
